# =============================================================================
# Vital Signs API — Environment Variables
# =============================================================================
# Local/Dev: Supabase Auth or Clerk for identity (Vault), Encore for infra.
# Production: Keycloak for identity, standalone infra.
# =============================================================================

# --- Environment ---
ENV=development                    # development | staging | production

# --- Auth Provider Selection ---
AUTH_PROVIDER=supabase             # supabase | clerk | keycloak

# --- Supabase Auth (local/dev — default Vault) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # set via `encore secret set SupabaseServiceRoleKey`
JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json

# --- Clerk (local/dev — alternative Vault) ---
# AUTH_PROVIDER=clerk
# CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...     # set via `encore secret set ClerkSecretKey`
# JWKS_URL=https://<clerk-frontend-api>/.well-known/jwks.json

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Rate Limiting ---
RATE_LIMIT_AUTH=10                 # per minute per IP
RATE_LIMIT_GENERAL=100             # per minute per user

# =============================================================================
# Production-only (ignored when running under Encore locally)
# =============================================================================

# --- Server ---
# PORT=5080                        # Encore assigns port automatically in local/dev

# --- Auth Provider: Keycloak (production Vault) ---
# AUTH_PROVIDER=keycloak
# KEYCLOAK_URL=https://keycloak.example.com
# KEYCLOAK_REALM=vital-signs
# KEYCLOAK_CLIENT_ID=vital-mobile-app
# KEYCLOAK_ADMIN_CLIENT_ID=vital-api-admin
# KEYCLOAK_ADMIN_CLIENT_SECRET=<from-vault>
# JWKS_URL=https://keycloak.example.com/realms/vital-signs/protocol/openid-connect/certs

# --- Database (standalone PostgreSQL + TimescaleDB) ---
# DATABASE_URL=postgres://user:pass@db-host:5432/vital_signs?sslmode=require
# DATABASE_MAX_CONNS=25
# DATABASE_MIN_CONNS=5

# --- Redis ---
# REDIS_URL=redis://redis-host:6379/0

# --- Observability (OTel — production only, Encore handles tracing locally) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_SERVICE_NAME=vital-api
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1
